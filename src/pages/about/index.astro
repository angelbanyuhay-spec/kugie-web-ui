---
import HomeLayout from '../../layouts/HomeLayout.astro';
import { ABOUT_CONTENT } from '../../data/about-data';
---

<HomeLayout
  title="About Us - Kugiebites"
  description="Our story, values, and commitment to compassionate care for your pets."
>
  <main class="about-page">
    <header class="about-header">
      <div class="container">
        <h1 class="page-title">{ABOUT_CONTENT.title}</h1>
        <div class="accent-line"></div>
      </div>
    </header>

    <section class="story-section">
      <div class="container story-grid">
        <div class="story-content">
          <h2 class="section-subtitle">{ABOUT_CONTENT.subtitle}</h2>
          <p class="story-text">{ABOUT_CONTENT.description}</p>
          <p class="story-text">{ABOUT_CONTENT.storyParagraph}</p>
        </div>
        <div class="story-image-wrapper">
          <div class="image-placeholder"></div>
        </div>
      </div>
    </section>

    <section class="values-section">
      <div class="container">
        <h2 class="values-title">Our Core Values</h2>
        <div class="values-grid">
          {ABOUT_CONTENT.values.map((value) => (
            <div class="value-card">
              <h3 class="value-name">{value.title}</h3>
              <p class="value-desc">{value.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</HomeLayout>

<style>
  :root {
    --color-green: #f49d03;
    --color-gold: #c8994f;
    --color-text: #333333;
    --color-light: #f9f9f9;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .about-page {
    font-family: 'Montserrat', sans-serif;
  }

  /* HEADER */
  .about-header {
    background-color: var(--color-green);
    padding: clamp(4rem, 8vw, 6rem) 0;
    text-align: center;
    color: white;
  }

  .page-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 1rem;
    margin-top: 0;
    font-weight: 800;
  }

  .accent-line {
    width: 80px;
    height: 4px;
    background-color: var(--color-gold);
    margin: 0 auto;
    border-radius: 2px;
  }

  /* STORY SECTION */
  .story-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background-color: var(--color-light);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .story-content {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .section-subtitle {
    font-family: 'Calistoga', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    color: var(--color-gold);
    margin: 0 0 0.5rem 0;
    font-weight: 800;
  }

  .story-text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0;
  }

  .story-image-wrapper {
    min-height: 280px;
  }

  .image-placeholder {
    width: 100%;
    height: 100%;
    min-height: 280px;
    background: linear-gradient(135deg, rgba(10, 68, 30, 0.08) 0%, rgba(187, 147, 19, 0.12) 100%);
    border-radius: 16px;
  }

  /* VALUES SECTION */
  .values-section {
    padding: clamp(3rem, 6vw, 5rem) 0;
    background-color: white;
  }

  .values-title {
    font-family: 'Calistoga', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-green);
    text-align: center;
    margin: 0 0 2.5rem 0;
    font-weight: 800;
  }

  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .values-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .value-card {
    background-color: var(--color-light);
    padding: 2rem 1.5rem;
    border-radius: 16px;
    border-left: 4px solid var(--color-gold);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .value-card:hover {
    box-shadow: 0 8px 24px rgba(10, 68, 30, 0.08);
    transform: translateY(-2px);
  }

  .value-name {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-green);
    margin: 0 0 0.75rem 0;
  }

  .value-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }
</style>
